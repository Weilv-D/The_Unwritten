{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__dashscope-websearch__bailian_web_search",
      "mcp__neo4j-cypher__get_neo4j_schema",
      "mcp__neo4j-cypher__read_neo4j_cypher",
      "mcp__neo4j-cypher__write_neo4j_cypher",
      "Bash(chmod 600:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-sensitive.sh\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-change.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/word-count-check.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
