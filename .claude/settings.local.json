{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__dashscope-websearch__bailian_web_search",
      "mcp__neo4j-cypher__get_neo4j_schema",
      "mcp__neo4j-cypher__read_neo4j_cypher",
      "mcp__neo4j-cypher__write_neo4j_cypher"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/Guard-Sensitive.ps1\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/Log-Change.ps1\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/Word-Count-Check.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
