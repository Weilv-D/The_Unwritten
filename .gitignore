# ====================================
# The Unwritten - 小说项目 .gitignore
# 支持百万字超长篇小说的版本控制配置
# ====================================

# ------------------------------------
# 编辑器和IDE临时文件
# ------------------------------------
*~
*.swp
*.swo
.*.sw[a-z]
*.tmp
*.temp

# ------------------------------------
# 操作系统文件
# ------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ------------------------------------
# 编辑器和IDE配置
# ------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ------------------------------------
# 导出文件和二进制文件
# ------------------------------------
*.pdf
*.epub
*.mobi
*.docx
*.doc
*.rtf
*.odt

# ------------------------------------
# 临时草稿（选择性忽略）
# ------------------------------------
# 保留有意义的草稿，忽略临时笔记
notes-temp.md
scratch-*.md
temp-*.md
draft-*.md

# ------------------------------------
# 备份文件
# ------------------------------------
*.bak
*.backup
*.old

# ------------------------------------
# 私人内容（不希望被版本控制的）
# ------------------------------------
private/
personal-notes.md
journal.md

# ------------------------------------
# AI辅助工具生成的临时文件
# ------------------------------------
ai-temp-*.md
claude-draft-*.md

# ------------------------------------
# 拼写检查和词典
# ------------------------------------
*.dic
.dictionaries/
.spell/

# ------------------------------------
# 大型媒体文件
# ------------------------------------
images/*.jpg
images/*.png
images/*.gif
reference-images/

# ------------------------------------
# 统计和分析文件
# ------------------------------------
stats/
analytics/
*.csv

# ------------------------------------
# 导出目录（通常不纳入版本控制）
# ------------------------------------
08_EXPORTS/
